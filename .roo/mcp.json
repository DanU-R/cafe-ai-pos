{
	"mcpServers": {
		"laravel-boost": {
			"command": "php",
			"args": [
				"artisan",
				"boost:mcp"
			],
			"alwaysAllow": [
				"browser-logs",
				"database-connections",
				"database-query",
				"database-schema",
				"get-absolute-url",
				"last-error",
				"read-log-entries",
				"search-docs",
				"application-info"
			]
		}
	}
}